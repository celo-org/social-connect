# Stage 1: Build the binary
FROM rust:bookworm AS build

WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY rust/ rust/

RUN cargo build --release -p odis-signer

# Stage 2: Runtime
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=build /app/target/release/odis-signer /bin/odis-signer

USER nobody
WORKDIR /app

ENTRYPOINT ["/bin/odis-signer"]
